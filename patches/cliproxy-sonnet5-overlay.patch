@@ -315,6 +321,61 @@ func getModels() *staticModelsJSON {
 	return modelsCatalogStore.data
 }
 
+// mergeEmbeddedFallback appends any embedded model definitions whose IDs are
+// absent from the remote catalog, per provider section. Remote definitions
+// always take precedence; embedded entries only fill gaps. This keeps a model
+// that shipped ahead of the upstream registry available until the registry
+// catches up, at which point the overlay is a no-op.
+func mergeEmbeddedFallback(remote *staticModelsJSON) {
+	if remote == nil {
+		return
+	}
+	var embedded staticModelsJSON
+	if err := json.Unmarshal(embeddedModelsJSON, &embedded); err != nil {
+		return
+	}
+
+	fill := func(remoteList, embeddedList []*ModelInfo) []*ModelInfo {
+		if len(embeddedList) == 0 {
+			return remoteList
+		}
+		present := make(map[string]struct{}, len(remoteList))
+		for _, m := range remoteList {
+			if m != nil {
+				present[strings.TrimSpace(m.ID)] = struct{}{}
+			}
+		}
+		for _, m := range embeddedList {
+			if m == nil {
+				continue
+			}
+			id := strings.TrimSpace(m.ID)
+			if id == "" {
+				continue
+			}
+			if _, ok := present[id]; ok {
+				continue
+			}
+			present[id] = struct{}{}
+			remoteList = append(remoteList, m)
+			log.Infof("model catalog: retaining embedded model %q absent from remote catalog", id)
+		}
+		return remoteList
+	}
+
+	remote.Claude = fill(remote.Claude, embedded.Claude)
+	remote.Gemini = fill(remote.Gemini, embedded.Gemini)
+	remote.Vertex = fill(remote.Vertex, embedded.Vertex)
+	remote.AIStudio = fill(remote.AIStudio, embedded.AIStudio)
+	remote.CodexFree = fill(remote.CodexFree, embedded.CodexFree)
+	remote.CodexTeam = fill(remote.CodexTeam, embedded.CodexTeam)
+	remote.CodexPlus = fill(remote.CodexPlus, embedded.CodexPlus)
+	remote.CodexPro = fill(remote.CodexPro, embedded.CodexPro)
+	remote.Kimi = fill(remote.Kimi, embedded.Kimi)
+	remote.Antigravity = fill(remote.Antigravity, embedded.Antigravity)
+	remote.XAI = fill(remote.XAI, embedded.XAI)
+}
